  "components": {
    "schemas": {
      "SportalSuperAdminApi_Comm_Dto_Login_Request_LoginDto": {
        "required": ["loginId", "loginPw"],
        "type": "object",
        "properties": {
          "loginId": { "minLength": 1, "type": "string" },
          "loginPw": { "minLength": 1, "type": "string" }
        },
        "additionalProperties": false
      },
      "SportalSuperAdminApi_Comm_Dto_Login_Request_RefreshTokenDto": {
        "required": ["refreshToken"],
        "type": "object",
        "properties": {
          "refreshToken": { "minLength": 1, "type": "string" }
        },
        "additionalProperties": false
      },
      "SportalSuperAdminApi_Comm_Dto_Register_Master_Request_AddMainMasterDto": {
        "required": ["deptName", "job", "licenseKey", "loginId", "loginPw", "name", "role"],
        "type": "object",
        "properties": {
          "loginId": { "minLength": 1, "type": "string" },
          "loginPw": { "minLength": 1, "type": "string" },
          "name": { "minLength": 1, "type": "string" },
          "company": { "type": "string", "nullable": true },
          "deptName": { "minLength": 1, "type": "string" },
          "job": { "minLength": 1, "type": "string" },
          "role": { "type": "integer", "format": "int32" },
          "licenseKey": { "minLength": 1, "type": "string" }
        },
        "additionalProperties": false
      },
      "SportalSuperAdminApi_Comm_Dto_Register_Master_Request_ExistsMainMasterLoginIdDto": {
        "required": ["loginId"],
        "type": "object",
        "properties": {
          "loginId": { "minLength": 1, "type": "string" }
        },
        "additionalProperties": false
      },
      "SportalSuperAdminApi_Comm_Dto_Register_Master_Request_SendMainMasterInviteDto": {
        "required": ["licenseKey", "receiver"],
        "type": "object",
        "properties": {
          "licenseKey": { "minLength": 1, "type": "string" },
          "receiver": { "minLength": 1, "type": "string" }
        },
        "additionalProperties": false
      },
      "SportalSuperAdminApi_Comm_Dto_Register_SuperMaster_Request_AddSuperMasterDto": {
        "required": ["deptName", "job", "loginId", "loginPw", "name"],
        "type": "object",
        "properties": {
          "loginId": { "minLength": 1, "type": "string" },
          "loginPw": { "minLength": 8, "type": "string" },
          "name": { "minLength": 1, "type": "string" },
          "deptName": { "minLength": 1, "type": "string" },
          "job": { "minLength": 1, "type": "string" }
        },
        "additionalProperties": false
      },
      "SportalSuperAdminApi_Comm_Dto_Register_SuperMaster_Request_ExistsSuperMasterLoginIdDto": {
        "required": ["loginId"],
        "type": "object",
        "properties": {
          "loginId": { "minLength": 1, "type": "string" }
        },
        "additionalProperties": false
      },
      "SportalSuperAdminApi_Comm_Dto_Register_SuperMaster_Request_SendSuperMasterInviteDto": {
        "type": "object",
        "properties": {
          "receiver": { "type": "string", "nullable": true }
        },
        "additionalProperties": false
      },
      "SportalSuperAdminApi_Comm_Dto_Site_Request_AddCreditIssueDto": {
        "required": ["creditCount", "siteKey"],
        "type": "object",
        "properties": {
          "siteKey": { "minLength": 1, "type": "string" },
          "creditCount": { "type": "integer", "format": "int32" }
        },
        "additionalProperties": false
      },
      "SportalSuperAdminApi_Comm_Dto_Site_Request_AddSiteDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "nullable": true },
          "creditCount": { "type": "integer", "format": "int32" },
          "autoIssue": { "type": "boolean" },
          "viewNameYn": { "type": "boolean" },
          "viewDeptYn": { "type": "boolean" },
          "viewJobYn": { "type": "boolean" },
          "viewCompanyYn": { "type": "boolean" },
          "viewSabunYn": { "type": "boolean" },
          "viewEndYn": { "type": "boolean" },
          "qrTimeOut": { "type": "integer", "format": "int32" },
          "sendEmail": { "type": "string", "nullable": true },
          "syncUrl": { "type": "string", "nullable": true }
        },
        "additionalProperties": false
      },
      "SportalSuperAdminApi_Comm_Dto_Site_Request_UpdateSiteDto": {
        "required": ["siteKey"],
        "type": "object",
        "properties": {
          "siteKey": { "minLength": 1, "type": "string" },
          "name": { "type": "string", "nullable": true },
          "autoIssue": { "type": "boolean", "nullable": true },
          "viewNameYn": { "type": "boolean", "nullable": true },
          "viewDeptYn": { "type": "boolean", "nullable": true },
          "viewJobYn": { "type": "boolean", "nullable": true },
          "viewCompanyYn": { "type": "boolean", "nullable": true },
          "viewSabunYn": { "type": "boolean", "nullable": true },
          "viewEndDtYn": { "type": "boolean", "nullable": true },
          "qrTimeOut": { "type": "integer", "format": "int32", "nullable": true },
          "syncUrl": { "type": "string", "nullable": true }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "입력양식 - 'Bearer' [space] and then your token.\r\n                예: 'Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...'",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
  "security": [{ "Bearer": [] }],
  "tags": [
    { "name": "Login" },
    { "name": "Register" },
    { "name": "Site" }
  ]
}
